# --- Frontend (Vite) ---
VITE_APP_BASE_PATH=/sms
# Set to "false" on the self-hosted server to use the real backend instead of in-browser mock
VITE_USE_MOCK=false

# --- App ---
APP_URL=https://secretvoip.com/sms
PORT=3000
API_PORT=3001

# --- Database ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/secretvoip_sms

# --- Upstream SMS provider (server-side ONLY — never exposed to the browser) ---
SMS_UPSTREAM_BASE_URL=https://skytelecom.io/api
SMS_UPSTREAM_API_KEY=REPLACE_WITH_REAL_KEY
# Optional — only set if the upstream rejects Bearer auth.
# Defaults: header=Authorization, prefix="Bearer ". For raw `X-API-Key: <key>`:
#   SMS_UPSTREAM_AUTH_HEADER=X-API-Key
#   SMS_UPSTREAM_AUTH_PREFIX=
# SMS_UPSTREAM_AUTH_HEADER=Authorization
# SMS_UPSTREAM_AUTH_PREFIX=Bearer 
# Optional upstream HTTP timeout (ms). Default 20000.
# SMS_UPSTREAM_TIMEOUT_MS=20000

# --- Auth secrets ---
JWT_SECRET=REPLACE_ME
SESSION_SECRET=REPLACE_ME

# --- First admin (seeded on startup if no admin exists) ---
ADMIN_EMAIL=admin@secretvoip.com
ADMIN_TEMP_PASSWORD=ChangeMe!2026
